rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.createdAt is string;
    }

    function isValidWardrobeItem(data) {
      return data.keys().hasAll(['userId', 'imageUrl', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.imageUrl is string &&
             data.imageUrl.size() < 2048 &&
             data.category is string &&
             data.category.size() < 100 &&
             data.versatilityScore is number &&
             data.versatilityScore >= 0 && data.versatilityScore <= 10;
    }

    // Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'referenceSelfieUrl', 'onboardingComplete', 'harvestConfig', 'seenPitch']);

      match /wardrobe/{itemId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidWardrobeItem(request.resource.data) && isValidId(itemId);
        allow update: if isOwner(userId) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['category', 'tags', 'isArchived', 'isApproved', 'vibe', 'color']);
        allow delete: if isOwner(userId);
      }

      match /harvests/{harvestId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(harvestId);
        allow update: if isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'foundItemsCount']);
      }
    }
  }
}
